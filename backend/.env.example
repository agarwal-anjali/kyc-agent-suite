# Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Models
LLM_MODEL=gemini-3-flash-preview
VISION_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-001

# Vector Store
# Local: QDRANT_URL=http://localhost:6333
# Production (self-hosted on Azure): QDRANT_URL=http://qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=kyc_regulatory_corpus

# App
APP_ENV=development
LOG_LEVEL=INFO
FATF_COUNTRY_LIST_PATH=data/fatf_high_risk_countries.json

# CORS
# Local: ALLOWED_ORIGINS=["http://localhost:5173"]
# Production: ALLOWED_ORIGINS=["https://your-app.azurestaticapps.net"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:4173"]