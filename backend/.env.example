# Gemini
GOOGLE_API_KEY=google_api_key_here

# Models
LLM_MODEL=gemini-3-flash-preview
VISION_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-001

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=kyc_regulatory_corpus
QDRANT_API_KEY=qdrant_api_key_here

# App
APP_ENV=development
LOG_LEVEL=INFO

# Risk Scoring Thresholds (configurable)
IDENTITY_CONFIDENCE_THRESHOLD=0.75
DOCUMENT_VALIDITY_THRESHOLD=0.80

# FATF country list
FATF_COUNTRY_LIST_PATH=data/fatf_high_risk_countries.json